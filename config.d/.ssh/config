Host *
  StrictHostKeyChecking no
  AddKeysToAgent yes
  ForwardAgent yes
  # IdentitiesOnly yes
  ServerAliveInterval 60
  ServerAliveCountMax 60
  TCPKeepAlive yes
  ControlMaster  auto
  HashKnownHosts no
  # IdentityFile ~/secrets/private-key/arc
  # ControlPath    /tmp/%r@%h:%p

Include config.d/hosts/*
